# Required for shared database API routes.
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Required in production for anonymous visitor/IP hashing.
# VISITOR_HASH_SALT=replace-with-random-secret

# Required for /api/admin/* endpoints.
# ADMIN_TOKEN=replace-with-random-secret

# Optional Telegram notifications for new pending admin review items.
# TELEGRAM_BOT_TOKEN=123456789:replace-with-telegram-token
# TELEGRAM_ADMIN_CHAT_ID=123456789
# Optional. Can be the site base URL or the full /admin URL.
# ADMIN_URL=https://gothic-lockpick-database.vercel.app/admin

# Optional base URL path for non-root static hosting.
# VITE_BASE_PATH=/gothic/
